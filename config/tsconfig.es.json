{
  "compilerOptions": {
    "target": "ES2015",
    "module": "ES2020",
    "composite": true,
    "lib": ["ES2015", "DOM"],
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "declaration": true,
    "types": []
  }
}
